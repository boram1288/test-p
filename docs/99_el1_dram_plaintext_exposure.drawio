<mxfile host="app.diagrams.net" modified="2026-07-11T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="el1-dram-plaintext-exposure" name="EL1 침해 시 실행 중 DRAM 평문 노출">
    <mxGraphModel dx="1426" dy="827" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="저장 암호화만으로는 영상/AI/IP 자산 보호가 부족함&#xa;EL1 침해 시 실행 중 DRAM 평문 노출 경로" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1f4e79;strokeColor=#17365d;fontColor=#ffffff;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="30" width="1440" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="legend" value="목적: 재현 절차가 아닌 경영진 설득용 위협 흐름&#xa;범위: 공격 도구/주소/명령/코드 없이 보호 한계와 영향만 표시" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="1440" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="storage" value="저장 상태&#xa;영상/모델/키 자료는 디스크/플래시에서 암호화됨&#xa;&#xa;효과: 저장 매체 탈취 보호" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;align=center;" vertex="1" parent="1">
          <mxGeometry x="90" y="250" width="250" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="load" value="실행 준비&#xa;TEE/OS/Driver/App이 데이터를 사용하려면 복호화 필요&#xa;&#xa;결과: DRAM 내 작업 버퍼는 평문 상태" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="250" width="270" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="dram" value="실행 중 DRAM&#xa;Camera/AI HW 입력 Frame&#xa;AI 모델 Weight/Activation&#xa;전처리/후처리 Buffer&#xa;IP 자산/중간 산출물" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;align=center;" vertex="1" parent="1">
          <mxGeometry x="730" y="250" width="270" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="normal" value="정상 동작 관점&#xa;CPU EL1 Kernel/Driver는 실행 중 자원 관리 권한을 가짐&#xa;&#xa;메모리 매핑/Buffer 생명주기/Device I/O 경로 관여" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;align=center;" vertex="1" parent="1">
          <mxGeometry x="1060" y="250" width="360" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="compromise" value="전제: EL1 침해&#xa;Kernel/Driver 수준 권한 탈취&#xa;&#xa;예: 취약 Driver, 공급망 변조, 권한 상승 등&#xa;(구체 절차/도구 제외)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4cccc;strokeColor=#cc0000;fontSize=15;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="90" y="500" width="290" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="capability" value="침해 후 가능해지는 관찰면&#xa;1. 실행 중 Buffer 위치/매핑 파악&#xa;2. Kernel/Driver 경로에서 Buffer 참조&#xa;3. Device I/O 전후 평문 데이터 접근&#xa;4. Page Table/메모리 관리 정보 악용 가능성" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce5cd;strokeColor=#e69138;fontSize=15;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="440" y="500" width="350" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="exfil" value="노출 대상&#xa;영상 Frame/ROI&#xa;AI 모델 Weight&#xa;중간 Activation/Feature&#xa;전처리/후처리 결과&#xa;세션 중 사용되는 민감 자료" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ead1dc;strokeColor=#a64d79;fontSize=15;align=center;" vertex="1" parent="1">
          <mxGeometry x="850" y="500" width="290" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="impact" value="사업 영향&#xa;저장 암호화 우회: 저장 매체가 아니라 실행 순간을 노림&#xa;영상/AI/IP 자산 유출&#xa;모델 복제/역공학&#xa;고객 신뢰/규제/계약 리스크" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1210" y="500" width="300" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="boundary" value="핵심 메시지&#xa;EL1은 실행 중 평문을 관리하는 위치에 있으므로, EL1 보호만으로는 EL1 침해 이후의 DRAM 평문 노출을 막기 어렵다." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9ead3;strokeColor=#38761d;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="200" y="735" width="1200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="mitigation" value="설득 포인트: 필요한 추가 보호&#xa;EL2/EL3/TEE/Confidential VM 등 EL1보다 높은 신뢰 경계&#xa;DRAM/메모리 영역 격리 및 접근 제어&#xa;Camera/AI HW DMA 경로의 S2MPU 정책&#xa;실행 중 데이터 최소화/마스킹/수명 단축&#xa;감사/무결성 검증/침해 탐지" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe2f3;strokeColor=#3d85c6;fontSize=15;align=left;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="200" y="845" width="1200" height="105" as="geometry"/>
        </mxCell>
        <mxCell id="a1" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="storage" target="load">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="load" target="dram">
