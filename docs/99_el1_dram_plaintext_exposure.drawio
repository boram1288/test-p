        <mxCell id="a5" value="평문 관찰/수집 가능" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#cc0000;fontColor=#cc0000;fontStyle=1;" edge="1" parent="1" source="capability" target="exfil">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
