        <mxCell id="a4" value="권한 탈취 후" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#cc0000;fontColor=#cc0000;fontStyle=1;" edge="1" parent="1" source="compromise" target="capability">
          <mxGeometry relative="1" as="geometry"/>
