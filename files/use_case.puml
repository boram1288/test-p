@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor White
  BorderColor Black
}

actor "사용자" as User

rectangle "System" {

  usecase "UC-01. pVM 생성·시작·정지·종료" as UC01
  usecase "UC-02. 다중 pVM 동시 운용" as UC02
  usecase "UC-03. ISP·NPU 공유 사용" as UC03
  usecase "UC-04. 격리 도메인 간\n보안 데이터 전송" as UC04
  usecase "UC-05. 보안 워크로드 동적 탑재" as UC05
  usecase "UC-06. Secure OS\nENC/DEC 명령 전송" as UC06
  usecase "UC-07. pVM 모니터링 및\n장애 복구" as UC07
}

User --> UC01
User --> UC02
User --> UC03
User --> UC04
User --> UC05
User --> UC06
User --> UC07

@enduml